{
  "name": "run-bundlers",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:esbuild": "node configs/build-esbuild.js",
    "build:webpack": "npm run build:webpack-swc && npm run build:webpack-uglifyjs && npm run build:webpack-esbuild && npm run build:webpack-terser",
    "build:webpack-swc": "webpack --config configs/webpack.swc.config.js",
    "build:webpack-uglifyjs": "webpack --config configs/webpack.uglifyjs.config.js",
    "build:webpack-esbuild": "webpack --config configs/webpack.esbuild.config.js",
    "build:webpack-terser": "webpack --config configs/webpack.terser.config.js",
    "build:rollup": "rollup -c configs/rollup.config.js --bundleConfigAsCjs",
    "build:vite": "npm run build:vite-esbuild && npm run build:vite-terser",
    "build:vite-esbuild": "vite build --config configs/vite.esbuild.config.js",
    "build:vite-terser": "vite build --config configs/vite.terser.config.js",
    "build:parcel": "npm run build:parcel-swc && npm run build:parcel-terser",
    "build:parcel-swc": "parcel build src/app.js --dist-dir build/parcel-swc",
    "build:parcel-terser": "parcel build src/app.js --dist-dir build/parcel-terser --config ./configs/.parcelrc",
    "build:all": "npm run build:esbuild && npm run build:webpack && npm run build:rollup && npm run build:vite && npm run build:parcel"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "7.26.0",
    "@babel/preset-react": "7.25.9",
    "@parcel/optimizer-terser": "2.13.2",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-commonjs": "28.0.1",
    "@rollup/plugin-node-resolve": "15.3.0",
    "@rollup/plugin-replace": "6.0.1",
    "@vitejs/plugin-react": "4.3.3",
    "babel-loader": "9.2.1",
    "esbuild": "0.24.0",
    "parcel": "2.13.2",
    "rollup": "4.26.0",
    "rollup-plugin-esbuild": "6.1.1",
    "terser": "5.36.0",
    "terser-webpack-plugin": "5.3.10",
    "uglify-js": "3.19.3",
    "vite": "5.4.11",
    "webpack": "5.96.1",
    "webpack-cli": "5.1.4"
  },
  "dependencies": {
    "jquery": "3.7.1"
  }
}
